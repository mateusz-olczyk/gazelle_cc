--- /dev/null
+++ BUILD.bazel
@@ -0,0 +1,16 @@
+load("@rules_cc//cc:defs.bzl", "cc_library")
+
+cc_library(
+    name = "tree-sitter-cpp",
+    srcs = glob([
+        "src/*.c",
+        "src/tree_sitter/*.h",
