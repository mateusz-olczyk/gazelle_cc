+    hdrs = ["bindings/c/tree-sitter-cpp.h"],
+    copts = [
+        "-std=c11",
+        "-fPIC",
+    ],
+    strip_include_prefix = "bindings/c",
+    visibility = ["//visibility:public"],
+)

